# Secrets — never commit API keys
.env
*.env

# Python
__pycache__/
*.pyc
.venv/
venv/

# Per-event bulk data: raw acquisitions and clean tapes are too large for
# GitHub (up to 550MB) and fully regenerable via src/fetch_* + src/clean_*.
# Everything else in events/ IS versioned: event.json, results/, reference/.
events/*/raw/
events/*/clean/
*.log
*.checkpoint.json

# Delivery bundles (large, derived — regenerate from scripts, don't version)
delivery*/
*.zip
*.gz

# OS / editor
.DS_Store
.ipynb_checkpoints/
